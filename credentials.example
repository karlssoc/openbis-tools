# OpenBIS credentials — copy to ~/.openbis/credentials and fill in your details.
# Lines starting with # are ignored.  Values may optionally be quoted.

OPENBIS_URL=https://your-server.com/openbis/
OPENBIS_USERNAME=your_username
OPENBIS_PASSWORD=your_password

# Optional: default download directory (default: ~/data/openbis)
# OBTOOLS_DOWNLOAD_DIR=~/data/openbis

# Optional: verify SSL certificates (default: false — set true for production)
# OBTOOLS_VERIFY_CERTS=false
